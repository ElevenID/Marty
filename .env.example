# Marty Development Environment Variables
# ==========================================
# Copy this file to .env and fill in values.
# Docker Compose reads .env automatically.
#
# WARNING: Never commit .env to version control.
#
# ── Naming Convention ─────────────────────────────────────────────────
# Backend services: UPPERCASE_WITH_UNDERSCORES
# Service-scoped:  SERVICE_VARIABLE  e.g. TRUST_SVC_ADMIN_API_KEY
# Infrastructure:  COMPONENT_VARIABLE e.g. POSTGRES_PASSWORD
# Frontend (Vite): VITE_VARIABLE       e.g. VITE_API_URL
# ─────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_postgres
KEYCLOAK_DB_PASSWORD=change_me_keycloak
APPLICANT_DB_PASSWORD=change_me_applicant

# ── Keycloak ──────────────────────────────────────────────────────────
KEYCLOAK_ADMIN_PASSWORD=change_me_admin
KEYCLOAK_REALM=11id
KC_HOSTNAME=localhost
KC_HOSTNAME_PORT=8180

# ── Demo Users ────────────────────────────────────────────────────────
DEMO_ADMIN_PASSWORD=change_me_demo_admin
DEMO_VENDOR_PASSWORD=change_me_demo_vendor
DEMO_APPLICANT_PASSWORD=change_me_demo_applicant

# ── OpenBao (KMS) ────────────────────────────────────────────────────
OPENBAO_ADDR=http://openbao:8200
OPENBAO_TOKEN=change_me_openbao_root_token

# ── Trust Service Admin ──────────────────────────────────────────────
TRUST_SVC_ADMIN_API_KEY=change_me_admin_api_key
TRUST_SNAPSHOT_SIGNING_KEY=change_me_signing_key

# ── Trust Service Rate Limiting ──────────────────────────────────────
TRUST_SVC_RATE_LIMIT_RPM=60

# =============================================================================
# Session & OID4VC
# =============================================================================
SESSION_SECRET=change_me_session_secret
STATUS_LIST_MASTER_KEY=change_me_status_list_key

# =============================================================================
# Object Storage (MinIO / S3)
# =============================================================================
S3_ENDPOINT=http://minio:9000
S3_BUCKET=marty-documents
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_minio_secret

# =============================================================================
# KMS / Vault
# =============================================================================
# Alternative names for the OpenBao vars above — code uses both conventions
VAULT_ADDR=http://openbao:8200
VAULT_TOKEN=change_me_vault_token
VAULT_AUTH_METHOD=token
# VAULT_ROLE=  # Required when VAULT_AUTH_METHOD=approle
KEY_VAULT_URL=http://openbao:8200
KMS_PROVIDER=mock
# KMS_KEY_ID=alias/marty-trust-signing
# KMS_REGION=us-east-1
ENFORCE_HSM_ATTESTATION=false

# =============================================================================
# PKD Service
# =============================================================================
PKD_API_KEY=change_me_pkd_api_key
PKD_SECRET_KEY=change_me_pkd_secret
PKD_DATABASE_URL=postgresql://marty_dev:marty_dev@localhost:5432/marty_pkd
PKD_SYNC_INTERVAL_HOURS=24
PKD_DATA_DIR=./data/pkd
# EXTERNAL_PKD_URL=
# EXTERNAL_PKD_USERNAME=
# EXTERNAL_PKD_PASSWORD=

# =============================================================================
# OpenXPKI (Certificate Authority)
# =============================================================================
# OPENXPKI_BASE_URL=https://pki.example.com
# OPENXPKI_USERNAME=
# OPENXPKI_PASSWORD=
# OPENXPKI_REALM=democa
# OPENXPKI_VERIFY_SSL=true

# =============================================================================
# Email / Notifications
# =============================================================================
# For SendGrid:
# SENDGRID_API_KEY=
# For SMTP (dev / Mailhog):
# SMTP_HOST=mailpit
# SMTP_PORT=1025
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=Marty

# =============================================================================
# Signing Keys (Notifications)
# =============================================================================
SIGNING_KEYS_API_KEY=change_me_signing_keys_api_key
# MARTY_SIGNING_PRIVATE_KEY=  # PEM-encoded; set in production
# MARTY_SIGNING_KEY_PASSWORD=
# MARTY_SIGNING_KEY_ID=default

# =============================================================================
# CMC Engine
# =============================================================================
CMC_ENGINE_HOST=localhost
CMC_ENGINE_PORT=8088

# =============================================================================
# Trust Service (Extended)
# =============================================================================
TRUST_DB_HOST=localhost
TRUST_DB_PORT=5432
TRUST_DB_NAME=marty_trust
TRUST_DB_USER=marty_dev
TRUST_DB_PASSWORD=change_me_trust_db
LOG_LEVEL=INFO
SCHEDULER_ENABLED=true
CRL_REFRESH_CRON=0 */6 * * *
MASTER_LIST_SYNC_CRON=0 2 * * *
SNAPSHOT_CREATE_CRON=0 4 * * *

# =============================================================================
# Public Domain / URLs
# =============================================================================
PUBLIC_DOMAIN=localhost
UI_BASE_URL=http://localhost:3000

# =============================================================================
# Demo Mode
# =============================================================================
MARTY_DEMO_MODE=0
MARTY_ENV=development
ENVIRONMENT=development
